---
import Layout from '../layouts/Layout.astro';
import EncontradorDeEscalasDoMetodo from '../components/EncontradorDeEscalasDoMetodo';
import { SITE_AUTHOR } from '../data/site';
---

<Layout title="Encontrador de escalas do método" wide>
	<div class="mb-10 w-full">
		<h1>Encontrador de escalas do método</h1>
		<p class="mt-3 text-base text-music-muted md:text-lg">
			Ferramenta por <strong class="text-music-text">{SITE_AUTHOR}</strong>
		</p>
		<p class="mt-6 text-music-muted">
			Encaixe o desenho da escala maior sobre qualquer tônica e veja, para cada grau, qual
			modo grego surge e como nomear o intervalo de cada nota em relação à nova referência.
		</p>
	</div>

	<EncontradorDeEscalasDoMetodo client:load />
</Layout>
