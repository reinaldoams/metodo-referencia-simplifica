---
import Layout from '../layouts/Layout.astro';
import EncontradorDeEscalasDoMetodo from '../components/EncontradorDeEscalasDoMetodo';
---

<Layout title="Encontrador de escalas do método" wide>
	<div class="mb-10 w-full">
		<h1>Encontrador de escalas do método</h1>
		<p class="mt-6 text-music-muted">
			Encaixe o desenho da escala maior sobre qualquer tônica e descubra, para cada grau,
			qual modo grego surge e como nomear o intervalo de cada nota em relação à nova
			referência.
		</p>
	</div>

	<EncontradorDeEscalasDoMetodo client:load />
</Layout>
