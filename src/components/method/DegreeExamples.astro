---
import { getTranslations, type Locale } from '../../i18n';
import MethodSection from './MethodSection.astro';
import DegreeReveal from './DegreeReveal.tsx';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const de = t.method.degreeExamples as {
	title: string;
	subtitle: string;
	intro: string;
	examples: Array<{ note: string; result: string; degree: string; description: string }>;
	tonicPrefix: string;
};
---

<MethodSection title={de.title} subtitle={de.subtitle}>
	<p class="mb-8 w-full text-music-muted">{de.intro}</p>

	<div class="grid w-full gap-4 md:grid-cols-3">
		{
			de.examples.map((ex) => (
				<article class="flex flex-col rounded-xl border border-white/10 bg-music-surface/50 p-6 md:p-8">
					<div class="mb-4 flex items-center gap-4">
						<span class="flex size-14 items-center justify-center rounded-full bg-music-accent font-serif text-2xl text-music-on-accent md:size-16 md:text-3xl">
							{ex.note.charAt(0)}
						</span>
						<div>
							<p class="text-lg font-semibold text-music-text md:text-xl">
								{de.tonicPrefix} {ex.note}
							</p>
							<p class="text-base text-music-text md:text-lg">{ex.degree}</p>
						</div>
					</div>
					<p class="flex-1 text-base leading-relaxed text-music-muted md:text-lg">{ex.description}</p>
					<DegreeReveal
						client:load
						degree={ex.degree}
						result={ex.result}
						revealLabel={t.common.revealAnswer}
					/>
				</article>
			))
		}
	</div>
</MethodSection>
