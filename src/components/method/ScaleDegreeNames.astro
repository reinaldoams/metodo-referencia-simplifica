---
import { getTranslations, type Locale } from '../../i18n';
import MethodSection from './MethodSection.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const dn = t.method.degreeNames as {
	title: string;
	subtitle: string;
	tableHeaders: { degree: string; name: string; note: string };
	degrees: Array<{ n: number; name: string; alt: string }>;
	alterationsTitle: string;
	alterationsIntro: string;
	alterationsHeaders: { degree: string; back: string; forward: string };
	alterations: Array<{ degree: string; back: string; forward: string }>;
};
---

<MethodSection title={dn.title} subtitle={dn.subtitle}>
	<div class="mb-10 w-full overflow-x-auto rounded-xl border border-white/10">
		<table class="w-full min-w-[28rem] text-left text-base md:text-lg">
			<thead class="border-b border-white/10 bg-music-surface/60">
				<tr>
					<th class="px-5 py-4 font-medium text-music-text">{dn.tableHeaders.degree}</th>
					<th class="px-5 py-4 font-medium text-music-text">{dn.tableHeaders.name}</th>
					<th class="px-5 py-4 font-medium text-music-text">{dn.tableHeaders.note}</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-white/5">
				{
					dn.degrees.map((d) => (
						<tr class="bg-music-bg/20">
							<td class="px-5 py-4 font-mono text-music-text">{d.n}</td>
							<td class="px-5 py-4 font-medium text-music-text">{d.name}</td>
							<td class="px-5 py-4 text-music-muted">{d.alt}</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>

	<h3 class="mb-4 text-2xl md:text-3xl">{dn.alterationsTitle}</h3>
	<p class="mb-6 w-full text-music-muted">{dn.alterationsIntro}</p>

	<div class="w-full overflow-x-auto rounded-xl border border-white/10">
		<table class="w-full min-w-[32rem] text-left text-base md:text-lg">
			<thead class="border-b border-white/10 bg-music-surface/60">
				<tr>
					<th class="px-5 py-4 font-medium text-music-text">{dn.alterationsHeaders.degree}</th>
					<th class="px-5 py-4 font-medium text-music-text">{dn.alterationsHeaders.back}</th>
					<th class="px-5 py-4 font-medium text-music-text">{dn.alterationsHeaders.forward}</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-white/5">
				{
					dn.alterations.map((row) => (
						<tr class="bg-music-bg/20">
							<td class="px-5 py-4 font-medium text-music-text">{row.degree}</td>
							<td class="px-5 py-4 text-music-muted">{row.back}</td>
							<td class="px-5 py-4 text-music-muted">{row.forward}</td>
						</tr>
					))
				}
			</tbody>
		</table>
	</div>
</MethodSection>
