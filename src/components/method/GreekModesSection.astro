---
import MethodSection from './MethodSection.astro';

const modes = [
	{
		n: 1,
		degree: '1.º grau',
		name: 'Jônio',
		alias: 'Escala maior',
		description: 'A tônica coincide com o primeiro grau da escala maior. É a referência de partida.',
	},
	{
		n: 2,
		degree: '2.º grau',
		name: 'Dórico',
		alias: 'Segundo modo grego',
		description: 'A tônica cai sobre o segundo grau. Mesmas notas da escala maior, nova referência.',
	},
	{
		n: 3,
		degree: '3.º grau',
		name: 'Frígio',
		alias: 'Terceiro modo grego',
		description: 'A tônica cai sobre o terceiro grau. O arranjo de tons e semitons muda a coloração.',
	},
	{
		n: 4,
		degree: '4.º grau',
		name: 'Lídio',
		alias: 'Quarto modo grego',
		description: 'A tônica cai sobre o quarto grau. Brilho característico pela quarta aumentada implícita.',
	},
	{
		n: 5,
		degree: '5.º grau',
		name: 'Mixolídio',
		alias: 'Quinto modo grego',
		description: 'A tônica cai sobre o quinto grau. Sonoridade dominante, com sétima menor em relação à nova tônica.',
	},
	{
		n: 6,
		degree: '6.º grau',
		name: 'Eólio',
		alias: 'Escala menor natural',
		description:
			'A tônica cai sobre o sexto grau — este é o sexto modo grego, também conhecido como escala menor natural.',
	},
	{
		n: 7,
		degree: '7.º grau',
		name: 'Lócrio',
		alias: 'Sétimo modo grego',
		description: 'A tônica cai sobre o sétimo grau. O modo mais instável, raro como tonalidade principal.',
	},
];
---

<MethodSection
	id="modos-gregos"
	title="Como encontrar os modos gregos"
	subtitle="O mesmo desenho da escala maior — apenas muda qual nota você trata como tônica."
>
	<div class="mb-10 w-full space-y-5 text-music-muted">
		<p>
			Até aqui usamos <strong class="text-music-text">primeiro modo grego</strong>,{' '}
			<strong class="text-music-text">segundo modo grego</strong> e assim por diante — sem
			nomes tradicionais. A ideia é simples: o desenho da escala maior no braço{' '}
			<em>nunca muda de forma</em>. O que muda é qual nota você escolhe como referência
			(tônica).
		</p>
		<p>
			Imagine a escala de Sol maior encaixada no braço. Se você tratar{' '}
			<strong class="text-music-text">Sol</strong> como tônica, está no{' '}
			<strong class="text-music-text">primeiro modo grego</strong>. Se tratar{' '}
			<strong class="text-music-text">Lá</strong> (o segundo grau) como tônica, está no{' '}
			<strong class="text-music-text">segundo modo grego</strong> — as mesmas notas, mas
			reorganizadas a partir de outra referência.
		</p>
		<p>
			Repita para cada grau: terceiro grau como tônica → terceiro modo grego, quarto grau →
			quarto modo grego, e assim sucessivamente até o sétimo grau. É por isso que, ao dominar
			um único desenho da escala maior, você acessa todos os modos — e a escala menor natural,
			que é o sexto modo grego.
		</p>
	</div>

	<div class="mb-12 w-full rounded-2xl border border-music-accent/25 bg-music-accent/5 p-6 md:p-8">
		<h3 class="mb-4 text-2xl md:text-3xl">Resumo visual</h3>
		<svg viewBox="0 0 600 120" class="w-full text-music-muted" aria-hidden="true">
			<defs>
				<marker id="mode-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
					<path d="M0,0 L6,3 L0,6 Z" fill="#bd93f9"></path>
				</marker>
			</defs>
			<rect x="10" y="40" width="580" height="40" rx="8" fill="#21222c" stroke="#bd93f9" stroke-opacity="0.3"></rect>
			{
				['Sol', 'Lá', 'Si', 'Dó', 'Ré', 'Mi', 'Fá♯'].map((note, i) => (
					<g>
						<circle cx={60 + i * 78} cy="60" r="18" fill={i === 0 ? '#bd93f9' : '#383a59'} stroke="#bd93f9" stroke-width="1.5"></circle>
						<text x={60 + i * 78} y="64" text-anchor="middle" fill={i === 0 ? '#282a36' : '#f8f8f2'} font-size="13" font-weight="bold">
							{note}
						</text>
						<text x={60 + i * 78} y="100" text-anchor="middle" fill="#f8f8f2" font-size="11">
							{i + 1}.º modo
						</text>
					</g>
				))
			}
		</svg>
		<p class="mt-4 text-music-muted">
			Em Sol maior: cada nota da escala, ao ser tratada como tônica, gera um modo grego
			diferente.
		</p>
	</div>

	<h3 class="mb-6 text-2xl md:text-3xl">Dar nomes aos bois</h3>
	<p class="mb-8 w-full text-music-muted">
		Quando estiver confortável com a numeração, estes são os nomes tradicionais de cada modo
		grego:
	</p>

	<div class="grid w-full gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{
			modes.map((mode) => (
				<article class="rounded-xl border border-white/10 bg-music-surface/50 p-6">
					<span class="mb-2 inline-block rounded-full bg-music-accent/15 px-3 py-1 text-sm font-medium text-music-text md:text-base">
						{mode.n}.º modo grego
					</span>
					<h4 class="text-xl md:text-2xl">{mode.name}</h4>
					<p class="mb-2 text-sm text-music-text md:text-base">{mode.alias}</p>
					<p class="text-base leading-relaxed text-music-muted md:text-lg">{mode.description}</p>
					<p class="mt-3 text-sm text-music-muted md:text-base">Tônica sobre o {mode.degree}</p>
				</article>
			))
		}
	</div>
</MethodSection>
