---
import { SITE_AUTHOR, SITE_AUTHOR_PORTFOLIO_URL } from '../data/site';
import { AUTHOR_LINK_CLASS } from '../lib/author-link';

interface Props {
	class?: string;
}

const className = Astro.props.class ?? AUTHOR_LINK_CLASS;
---

<a href={SITE_AUTHOR_PORTFOLIO_URL} target="_blank" rel="noopener noreferrer" class={className}>
	{SITE_AUTHOR}
</a>
