---
interface Props {
	href: string;
	label: string;
}

const { href, label } = Astro.props;
---

<a
	href={href}
	class="mt-4 inline-block rounded-lg border border-music-accent/50 px-5 py-2.5 font-medium text-music-text no-underline transition-colors hover:border-music-accent hover:bg-music-accent/10"
>
	{label} →
</a>
