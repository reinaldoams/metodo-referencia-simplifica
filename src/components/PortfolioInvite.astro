---
import AuthorMention from './AuthorMention.astro';

interface Props {
	title: string;
	body: string;
	button: string;
	url: string;
}

const { title, body, button, url } = Astro.props;
---

<section
	class="mt-8 rounded-2xl border border-white/10 bg-music-surface/40 px-8 py-10 text-center md:px-14"
>
	<h2 class="mb-3 text-xl md:text-2xl">{title}</h2>
	<p class="mx-auto mb-6 max-w-lg text-music-muted">
		<AuthorMention template={body} />
	</p>
	<a
		href={url}
		target="_blank"
		rel="noopener noreferrer"
		class="inline-block rounded-lg border border-music-accent/50 px-6 py-3 font-medium text-music-text no-underline transition-colors hover:border-music-accent hover:bg-music-accent/10"
	>
		{button}
	</a>
</section>
