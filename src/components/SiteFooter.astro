---
import { getTranslations, type Locale } from '../i18n';
import AuthorMention from './AuthorMention.astro';

interface Props {
	locale?: Locale;
}

const locale = (Astro.props.locale ?? Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
---

<footer class="border-t border-white/10 bg-music-surface/40 px-6 py-8 text-center text-base text-music-muted">
	<p>
		<AuthorMention template={t.footer} />
	</p>
</footer>
