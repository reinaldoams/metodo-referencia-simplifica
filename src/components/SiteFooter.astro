---
import { getTranslations, type Locale } from '../i18n';
import { SITE_AUTHOR } from '../data/site';

interface Props {
	locale?: Locale;
}

const locale = (Astro.props.locale ?? Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const [beforeAuthor, afterAuthor] = t.footer.split('{author}');
---

<footer class="border-t border-white/10 bg-music-surface/40 px-6 py-8 text-center text-base text-music-muted">
	<p>
		{beforeAuthor}<strong class="font-medium text-music-text">{SITE_AUTHOR}</strong>{afterAuthor}
	</p>
</footer>
