---
import AuthorLink from '../components/AuthorLink.astro';
import EncontradorDeNotas from '../components/EncontradorDeNotas';
import { getTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const page = t.noteFinderPage as {
	title: string;
	p1: string;
	p2: string;
	p3: string;
	p4: string;
};
---

<div class="mb-10 max-w-3xl space-y-4">
	<h1>{page.title}</h1>
	<p class="mt-3 text-base text-music-muted md:text-lg">
		{t.author.toolBy} <AuthorLink />
	</p>
	<p class="text-music-muted">{page.p1}</p>
	<p class="text-music-muted">{page.p2}</p>
	<p class="text-music-muted">{page.p3}</p>
	<p class="text-music-muted">{page.p4}</p>
</div>

<EncontradorDeNotas client:load locale={locale} />
