---
import AuthorLink from '../components/AuthorLink.astro';
import EncontradorDeEscalasDoMetodo from '../components/EncontradorDeEscalasDoMetodo';
import { getTranslations, type Locale } from '../i18n';

const locale = (Astro.currentLocale ?? 'pt') as Locale;
const t = getTranslations(locale);
const page = t.scaleFinderPage as { title: string; intro: string };
---

<div class="mb-10 w-full">
	<h1>{page.title}</h1>
	<p class="mt-3 text-base text-music-muted md:text-lg">
		{t.author.toolBy} <AuthorLink />
	</p>
	<p class="mt-6 text-music-muted">{page.intro}</p>
</div>

<EncontradorDeEscalasDoMetodo client:load locale={locale} />
